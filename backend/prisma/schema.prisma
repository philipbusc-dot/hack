// SafeHAIVN — Pandemic Survival Intelligence System
// Prisma schema. Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Feature 4 — AI Survival Briefing System
model KnowledgeArticle {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  source    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Authentication — site accounts.
// role: "admin" (may edit Map data) | "survivor" (standard user).
// Signup only ever creates survivors; admins are seeded (see prisma/seed.ts).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  role         String   @default("survivor")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Profile / survivor display fields (Connect + Profile features).
  // Optional so a fresh signup is valid; populated via the profile editor.
  photoUrl     String? // avatar shown in Connect + Profile
  description  String? // "about me" / bio
  lat          Float? // for nearby matching
  lng          Float?
  age          Int?
  baseLocation String?

  // Cached Connect compatibility opinion (AI-generated, lazy). Null = not yet
  // generated or invalidated after a description/stats edit; regenerated on next view.
  aiOpinion String?

  // Optional: a survivor isn't required to pick a country at signup.
  // Populated later by the risk/connect features.
  countryId String?
  country   Country? @relation(fields: [countryId], references: [id])

  stats SurvivalStat[]
}

model SurvivalStat {
  id     String @id @default(cuid())
  name   String
  value  Float
  unit   String @default("days") // denominator for the value, e.g. "days", "kg", "L"
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RegionRisk {
  id      String @id @default(cuid())
  country String @unique // one profile per country
  lat     Float
  lng     Float

  // source factors (live + derived)
  infectionRate     Float
  humidity          Float
  populationDensity Float
  airportTraffic    Float
  hospitalPressure  Float

  // computed 0–100 macro score
  regionalScore Float

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  countries Country[]
}

model Country {
  id                String @id @default(cuid())
  name              String @unique // "Thailand"
  code              String @unique // "TH"
  lat               Float
  lng               Float
  // static seed factors (from your CSVs)
  populationDensity Float
  airportTraffic    Float

  users        User[]
  risk         RegionRisk? @relation(fields: [regionRiskId], references: [id]) // one live risk record per country
  regionRiskId String?
}

// Match / ChatMessage reference User.id via senderId/receiverId. These are
// intentionally loose string references (no FK), as before the User↔Survivor merge.
model Match {
  id         String   @id @default(uuid())
  senderId   String // User.id
  receiverId String // User.id
  status     String // "like", "love", "no"
  createdAt  DateTime @default(now())
}

model ChatMessage {
  id         String   @id @default(uuid())
  senderId   String // User.id
  receiverId String // User.id
  text       String
  timestamp  String // e.g. "03:14 AM"
  createdAt  DateTime @default(now())
}

model CountryReport {
  id          Int      @id @default(autoincrement())
  countryCode String
  countryName String
  topic       String   @default("") // per-report headline, e.g. "New variant detected"
  severity    String   @default("Moderate")
  cases       Int      @default(0)
  note        String   @default("")
  createAt    DateTime @default(now())
  updateAt    DateTime @updatedAt
}
