// SafeHAIVN — Pandemic Survival Intelligence System
// Prisma schema. Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Feature 4 — AI Survival Briefing System
model KnowledgeArticle {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  source    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Authentication — site accounts.
// role: "admin" (may edit Map data) | "survivor" (standard user).
// Signup only ever creates survivors; admins are seeded (see prisma/seed.ts).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  role         String   @default("survivor")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
